  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.5.2",
    "browserslist": "^4.21.0",
    "chosen-js": "^1.6.2",
    "compression": "^1.7.4",
    "cssnano": "^8.0.2",
    "dotenv": "^2.0.0",
    "enquire.js": "^2.1.1",
    "eslint": "^10.5.0",
    "eventemitter3": "^1.2.0",
